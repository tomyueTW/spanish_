  "grammar": [
    {
      "id": "g03",
      "topic": "estar 動詞",
      "q": "¿Cómo ___ tú?",
      "zh": "你好嗎？",
      "opts": [
        "soy",
        "eres",
        "estoy",
        "estás"
      ],
      "a": 3,
      "exp": "estar 第二人稱單數：tú estás。estar 表暫時狀態、位置。",
      "level": "L2"
    },
    {
      "id": "g10",
      "topic": "-ar 規則動詞",
      "q": "Yo ___ español todos los días.",
      "zh": "我每天說西班牙語",
      "opts": [
        "habla",
        "hablas",
        "hablo",
        "hablan"
      ],
      "a": 2,
      "exp": "hablar 第一人稱：yo hablo。-ar 動詞變位：-o/-as/-a/-amos/-áis/-an。",
      "level": "L2"
    },
    {
      "id": "g11",
      "topic": "-er 規則動詞",
      "q": "Nosotros ___ pizza los viernes.",
      "zh": "我們週五吃披薩",
      "opts": [
        "como",
        "comes",
        "come",
        "comemos"
      ],
      "a": 3,
      "exp": "comer 第一人稱複數：nosotros comemos。-er 動詞變位。",
      "level": "L2"
    },
    {
      "id": "g12",
      "topic": "-ir 規則動詞",
      "q": "Mi hermana ___ en Madrid.",
      "zh": "我姊姊住在馬德里",
      "opts": [
        "vivo",
        "vives",
        "vive",
        "viven"
      ],
      "a": 2,
      "exp": "vivir 第三人稱單數：ella vive。-ir 動詞變位。",
      "level": "L2"
    },
    {
      "id": "g13",
      "topic": "tener 動詞",
      "q": "Yo ___ veinte años.",
      "zh": "我 20 歲",
      "opts": [
        "soy",
        "estoy",
        "tengo",
        "tiene"
      ],
      "a": 2,
      "exp": "西班牙語表年齡用 tener（直譯：我擁有20年）。tengo 是 tener 第一人稱。",
      "level": "L2"
    },
    {
      "id": "g17",
      "topic": "反身動詞",
      "q": "Yo ___ Quentin.",
      "zh": "我叫 Quentin",
      "opts": [
        "llamo",
        "me llamo",
        "te llamas",
        "se llama"
      ],
      "a": 1,
      "exp": "llamarse 是反身動詞，「叫做」。第一人稱：me llamo。",
      "level": "L2"
    },
    {
      "id": "g22",
      "topic": "現在進行式",
      "q": "Estoy ___ un libro.",
      "zh": "我正在讀一本書",
      "opts": [
        "leer",
        "leyendo",
        "leído",
        "leo"
      ],
      "a": 1,
      "exp": "estar + gerundio 表進行式。leer → leyendo。",
      "level": "L2"
    }
  ],

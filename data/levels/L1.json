  "grammar": [
    {
      "id": "g01",
      "topic": "ser 動詞",
      "q": "Yo ___ profesor.",
      "zh": "我是老師",
      "opts": [
        "soy",
        "eres",
        "es",
        "somos"
      ],
      "a": 0,
      "exp": "ser 第一人稱單數：yo soy。ser 表身分、本質、職業。",
      "level": "L1"
    },
    {
      "id": "g02",
      "topic": "ser 動詞",
      "q": "Nosotros ___ amigos.",
      "zh": "我們是朋友",
      "opts": [
        "soy",
        "eres",
        "somos",
        "son"
      ],
      "a": 2,
      "exp": "ser 第一人稱複數：nosotros somos。",
      "level": "L1"
    },
    {
      "id": "g04",
      "topic": "ser vs estar",
      "q": "La sopa ___ caliente.",
      "zh": "湯是熱的（現在）",
      "opts": [
        "es",
        "está",
        "son",
        "están"
      ],
      "a": 1,
      "exp": "形容暫時狀態（現在這碗湯熱）用 estar。如果說 La sopa es caliente 會變成「湯（本質上）就是熱食」。",
      "level": "L1"
    },
    {
      "id": "g05",
      "topic": "定冠詞",
      "q": "___ libro está en la mesa.",
      "zh": "這本書在桌上",
      "opts": [
        "El",
        "La",
        "Los",
        "Las"
      ],
      "a": 0,
      "exp": "libro 陽性單數 → el。",
      "level": "L1"
    },
    {
      "id": "g06",
      "topic": "定冠詞",
      "q": "___ casas son grandes.",
      "zh": "這些房子很大",
      "opts": [
        "El",
        "La",
        "Los",
        "Las"
      ],
      "a": 3,
      "exp": "casas 陰性複數 → las。",
      "level": "L1"
    },
    {
      "id": "g07",
      "topic": "不定冠詞",

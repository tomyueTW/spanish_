  "grammar": [
    {
      "id": "g08",
      "topic": "形容詞性數配合",
      "q": "Las flores son ___.",
      "zh": "這些花很紅",
      "opts": [
        "rojo",
        "roja",
        "rojos",
        "rojas"
      ],
      "a": 3,
      "exp": "flores 陰性複數 → rojas。形容詞要與名詞配合。",
      "level": "L3"
    },
    {
      "id": "g09",
      "topic": "形容詞性數配合",
      "q": "Mis hermanos son ___.",
      "zh": "我的兄弟們很高",
      "opts": [
        "alto",
        "alta",
        "altos",
        "altas"
      ],
      "a": 2,
      "exp": "hermanos 陽性複數 → altos。",
      "level": "L3"
    },
    {
      "id": "g14",
      "topic": "ir + a + 不定式（近未來）",
      "q": "Mañana ___ a estudiar.",
      "zh": "明天我要去讀書",
      "opts": [
        "voy",
        "vas",
        "va",
        "vamos"
      ],
      "a": 0,
      "exp": "ir + a + infinitivo 表近未來。yo voy a estudiar = 我將要去讀書。",
      "level": "L3"
    },
    {
      "id": "g15",
      "topic": "gustar 結構",
      "q": "A mí me ___ el café.",
      "zh": "我喜歡咖啡",
      "opts": [
        "gusto",
        "gustas",
        "gusta",
        "gustan"
      ],
      "a": 2,
      "exp": "gustar 結構：主詞是被喜歡的事物。咖啡（單數）→ gusta。「我」用 me（間接受詞）。",
      "level": "L3"
    },
    {
      "id": "g16",
      "topic": "gustar 結構",
      "q": "A ella le ___ los gatos.",
      "zh": "她喜歡貓",
      "opts": [
        "gusto",
        "gusta",
        "gustan",
        "gustamos"
      ],
      "a": 2,
      "exp": "被喜歡的事物（gatos）是複數，所以動詞用 gustan。",
      "level": "L3"
    }
  ],

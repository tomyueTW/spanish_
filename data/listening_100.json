  "items": [
    {"id": "l001", "es": "Hola, ¿cómo estás?", "zh": "你好，你好嗎？", "topic": "問候"},
    {"id": "l002", "es": "Me llamo Carlos. ¿Y tú?", "zh": "我叫 Carlos，你呢？", "topic": "問候"},
    {"id": "l003", "es": "Mucho gusto en conocerte.", "zh": "很高興認識你。", "topic": "問候"},
    {"id": "l004", "es": "¿De dónde eres?", "zh": "你從哪裡來？", "topic": "問候"},
    {"id": "l005", "es": "Soy de Taiwán.", "zh": "我來自台灣。", "topic": "問候"},
    {"id": "l006", "es": "Buenos días, ¿qué tal?", "zh": "早安，最近如何？", "topic": "問候"},
    {"id": "l007", "es": "Hasta luego, nos vemos mañana.", "zh": "回頭見，明天見。", "topic": "問候"},
    {"id": "l008", "es": "Que tengas un buen día.", "zh": "祝你有美好的一天。", "topic": "問候"},
    {"id": "l009", "es": "Lo siento, no entiendo.", "zh": "對不起，我聽不懂。", "topic": "溝通"},
    {"id": "l010", "es": "¿Puedes hablar más despacio?", "zh": "你可以說慢一點嗎？", "topic": "溝通"},
    {"id": "l011", "es": "¿Cómo se dice esto en español?", "zh": "這個用西班牙語怎麼說？", "topic": "溝通"},
    {"id": "l012", "es": "¿Hablas inglés?", "zh": "你會說英語嗎？", "topic": "溝通"},
    {"id": "l013", "es": "Un poco, pero no muy bien.", "zh": "一點點，但不是很好。", "topic": "溝通"},
    {"id": "l014", "es": "Repite, por favor.", "zh": "請再說一次。", "topic": "溝通"},
    {"id": "l015", "es": "No sé.", "zh": "我不知道。", "topic": "溝通"},
    {"id": "l016", "es": "Tengo una pregunta.", "zh": "我有一個問題。", "topic": "溝通"},
    {"id": "l017", "es": "¿Qué hora es?", "zh": "現在幾點？", "topic": "時間"},
    {"id": "l018", "es": "Son las tres de la tarde.", "zh": "下午三點。", "topic": "時間"},
    {"id": "l019", "es": "Es la una en punto.", "zh": "一點整。", "topic": "時間"},
    {"id": "l020", "es": "¿Qué día es hoy?", "zh": "今天星期幾？", "topic": "時間"},
    {"id": "l021", "es": "Hoy es lunes.", "zh": "今天是星期一。", "topic": "時間"},
    {"id": "l022", "es": "Mañana voy al trabajo.", "zh": "明天我要去上班。", "topic": "時間"},
    {"id": "l023", "es": "El fin de semana descanso.", "zh": "週末我休息。", "topic": "時間"},
    {"id": "l024", "es": "Te veo a las ocho.", "zh": "八點見。", "topic": "時間"},
    {"id": "l025", "es": "Tengo hambre.", "zh": "我餓了。", "topic": "食物"},
    {"id": "l026", "es": "Tengo sed, quiero agua.", "zh": "我口渴，我想要水。", "topic": "食物"},
    {"id": "l027", "es": "¿Qué quieres comer?", "zh": "你想吃什麼？", "topic": "食物"},
    {"id": "l028", "es": "Me gusta mucho la comida española.", "zh": "我很喜歡西班牙菜。", "topic": "食物"},
    {"id": "l029", "es": "La cuenta, por favor.", "zh": "請給我帳單。", "topic": "食物"},
    {"id": "l030", "es": "Está muy rico.", "zh": "很好吃。", "topic": "食物"},
    {"id": "l031", "es": "Soy vegetariano.", "zh": "我吃素。", "topic": "食物"},
    {"id": "l032", "es": "¿Qué recomienda usted?", "zh": "您推薦什麼？", "topic": "食物"},
    {"id": "l033", "es": "Una mesa para dos, por favor.", "zh": "兩個人的位子，謝謝。", "topic": "食物"},
    {"id": "l034", "es": "Quiero un café con leche.", "zh": "我要一杯拿鐵。", "topic": "食物"},
    {"id": "l035", "es": "¿Cuánto cuesta?", "zh": "多少錢？", "topic": "購物"},
    {"id": "l036", "es": "Es muy caro.", "zh": "很貴。", "topic": "購物"},
    {"id": "l037", "es": "¿Tiene algo más barato?", "zh": "有比較便宜的嗎？", "topic": "購物"},
    {"id": "l038", "es": "Voy a pagar con tarjeta.", "zh": "我要用信用卡付。", "topic": "購物"},
    {"id": "l039", "es": "Sólo estoy mirando, gracias.", "zh": "我只是看看，謝謝。", "topic": "購物"},
    {"id": "l040", "es": "¿Puedo probarme esto?", "zh": "我可以試穿這個嗎？", "topic": "購物"},
    {"id": "l041", "es": "Me lo llevo.", "zh": "我買這個。", "topic": "購物"},
    {"id": "l042", "es": "¿Dónde está el baño?", "zh": "洗手間在哪？", "topic": "問路"},
    {"id": "l043", "es": "¿Cómo llego al centro?", "zh": "怎麼去市中心？", "topic": "問路"},
    {"id": "l044", "es": "Está cerca de aquí.", "zh": "離這裡很近。", "topic": "問路"},
    {"id": "l045", "es": "Está lejos.", "zh": "很遠。", "topic": "問路"},
    {"id": "l046", "es": "Sigue todo recto.", "zh": "一直往前走。", "topic": "問路"},
    {"id": "l047", "es": "Gira a la derecha.", "zh": "向右轉。", "topic": "問路"},
    {"id": "l048", "es": "Gira a la izquierda.", "zh": "向左轉。", "topic": "問路"},
    {"id": "l049", "es": "Estoy perdido.", "zh": "我迷路了。", "topic": "問路"},
    {"id": "l050", "es": "¿Hay un cajero por aquí?", "zh": "這附近有提款機嗎？", "topic": "問路"},
    {"id": "l051", "es": "Voy a tomar el metro.", "zh": "我要搭捷運。", "topic": "交通"},
    {"id": "l052", "es": "¿A qué hora sale el tren?", "zh": "火車幾點開？", "topic": "交通"},
    {"id": "l053", "es": "Necesito un taxi.", "zh": "我需要一輛計程車。", "topic": "交通"},
    {"id": "l054", "es": "Llévame al aeropuerto, por favor.", "zh": "請載我去機場。", "topic": "交通"},
    {"id": "l055", "es": "El vuelo está retrasado.", "zh": "班機延誤了。", "topic": "交通"},
    {"id": "l056", "es": "¿Cuánto tarda en llegar?", "zh": "到那要多久？", "topic": "交通"},
    {"id": "l057", "es": "Tengo dos maletas.", "zh": "我有兩個行李箱。", "topic": "交通"},
    {"id": "l058", "es": "¿Tienes una habitación libre?", "zh": "你有空房嗎？", "topic": "旅館"},
    {"id": "l059", "es": "Quiero una habitación doble.", "zh": "我要一間雙人房。", "topic": "旅館"},
    {"id": "l060", "es": "¿Cuánto cuesta por noche?", "zh": "一晚多少錢？", "topic": "旅館"},
    {"id": "l061", "es": "¿A qué hora es el desayuno?", "zh": "早餐幾點？", "topic": "旅館"},
    {"id": "l062", "es": "El wifi no funciona.", "zh": "Wi-Fi 不能用。", "topic": "旅館"},
    {"id": "l063", "es": "Tengo frío.", "zh": "我冷。", "topic": "感受"},
    {"id": "l064", "es": "Tengo calor.", "zh": "我熱。", "topic": "感受"},
    {"id": "l065", "es": "Estoy muy cansado.", "zh": "我很累。", "topic": "感受"},
    {"id": "l066", "es": "Estoy contento.", "zh": "我很開心。", "topic": "感受"},
    {"id": "l067", "es": "Me siento mal.", "zh": "我覺得不舒服。", "topic": "感受"},
    {"id": "l068", "es": "Estoy enfermo.", "zh": "我生病了。", "topic": "感受"},
    {"id": "l069", "es": "Me duele la cabeza.", "zh": "我頭痛。", "topic": "健康"},
    {"id": "l070", "es": "Necesito un médico.", "zh": "我需要醫生。", "topic": "健康"},
    {"id": "l071", "es": "¿Dónde está la farmacia?", "zh": "藥局在哪？", "topic": "健康"},
    {"id": "l072", "es": "Llama a la ambulancia.", "zh": "叫救護車。", "topic": "緊急"},
    {"id": "l073", "es": "¡Socorro!", "zh": "救命！", "topic": "緊急"},
    {"id": "l074", "es": "¡Cuidado!", "zh": "小心！", "topic": "緊急"},
    {"id": "l075", "es": "¿Qué tiempo hace hoy?", "zh": "今天天氣如何？", "topic": "天氣"},
    {"id": "l076", "es": "Hace sol.", "zh": "出太陽。", "topic": "天氣"},
    {"id": "l077", "es": "Está lloviendo.", "zh": "正在下雨。", "topic": "天氣"},
    {"id": "l078", "es": "Hace mucho frío hoy.", "zh": "今天很冷。", "topic": "天氣"},
    {"id": "l079", "es": "Mañana va a llover.", "zh": "明天會下雨。", "topic": "天氣"},
    {"id": "l080", "es": "Te quiero.", "zh": "我愛你。", "topic": "情感"},
    {"id": "l081", "es": "Te echo de menos.", "zh": "我想你。", "topic": "情感"},
    {"id": "l082", "es": "Eres muy amable.", "zh": "你人真好。", "topic": "情感"},
    {"id": "l083", "es": "¡Qué bonito!", "zh": "好漂亮！", "topic": "讚美"},
    {"id": "l084", "es": "¡Qué interesante!", "zh": "好有趣！", "topic": "讚美"},
    {"id": "l085", "es": "Estoy de acuerdo.", "zh": "我同意。", "topic": "意見"},
    {"id": "l086", "es": "No estoy de acuerdo.", "zh": "我不同意。", "topic": "意見"},
    {"id": "l087", "es": "Creo que sí.", "zh": "我覺得是。", "topic": "意見"},
    {"id": "l088", "es": "No estoy seguro.", "zh": "我不確定。", "topic": "意見"},
    {"id": "l089", "es": "Depende.", "zh": "看情況。", "topic": "意見"},
    {"id": "l090", "es": "¿Qué te parece?", "zh": "你覺得呢？", "topic": "意見"},
    {"id": "l091", "es": "Voy a la escuela.", "zh": "我去學校。", "topic": "日常"},
    {"id": "l092", "es": "Trabajo en una oficina.", "zh": "我在辦公室工作。", "topic": "日常"},
    {"id": "l093", "es": "Estudio español.", "zh": "我學西班牙語。", "topic": "日常"},
    {"id": "l094", "es": "Vivo en Taipei.", "zh": "我住在台北。", "topic": "日常"},
    {"id": "l095", "es": "Tengo dos hermanos.", "zh": "我有兩個兄弟。", "topic": "日常"},
    {"id": "l096", "es": "Mi color favorito es el azul.", "zh": "我最喜歡的顏色是藍色。", "topic": "日常"},
    {"id": "l097", "es": "¿Tienes hijos?", "zh": "你有小孩嗎？", "topic": "日常"},
    {"id": "l098", "es": "Voy a casa.", "zh": "我要回家。", "topic": "日常"},
    {"id": "l099", "es": "¡Feliz cumpleaños!", "zh": "生日快樂！", "topic": "祝賀"},
    {"id": "l100", "es": "¡Feliz Navidad!", "zh": "聖誕快樂！", "topic": "祝賀"}
  ]

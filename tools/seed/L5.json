  "grammar": [
    {"topic": "未完成過去式", "q": "Cuando era pequeño, ___ con mis amigos cada día.", "zh": "我小時候每天和朋友玩。", "opts": ["jugaba", "jugué", "juego", "jugaré"], "a": 0, "exp": "imperfecto 表過去習慣性動作；jugar 第一人稱單數為 jugaba。"},
    {"topic": "未完成過去式 ser", "q": "Antes esta ciudad ___ mucho más tranquila.", "zh": "以前這座城市安靜多了。", "opts": ["era", "fue", "es", "será"], "a": 0, "exp": "ser 的 imperfecto 第三人稱單數為 era，用於描述過去狀態。"},
    {"topic": "未完成過去式 ir", "q": "Todos los veranos nosotros ___ a la playa.", "zh": "每年夏天我們都會去海邊。", "opts": ["íbamos", "fuimos", "vamos", "iremos"], "a": 0, "exp": "ir 的 imperfecto 第一人稱複數為 íbamos，表過去反覆的習慣。"},
    {"topic": "未完成過去式 había", "q": "___ mucha gente en la fiesta de anoche.", "zh": "昨晚的派對上有很多人。", "opts": ["Había", "Hubo", "Hay", "Habrá"], "a": 0, "exp": "描述過去背景情境時，hay 的 imperfecto 為 había。"},
    {"topic": "indefinido vs imperfecto", "q": "Mientras yo ___, sonó el teléfono.", "zh": "我正在睡覺時，電話響了。", "opts": ["dormía", "dormí", "duermo", "dormiré"], "a": 0, "exp": "持續的背景動作用 imperfecto（dormía），打斷它的瞬間動作用 indefinido（sonó）。"},
    {"topic": "indefinido vs imperfecto", "q": "Ayer ___ a las ocho y desayuné rápido.", "zh": "我昨天八點起床，很快吃了早餐。", "opts": ["me levanté", "me levantaba", "me levanto", "me levantaré"], "a": 0, "exp": "已完成的單一過去動作用 indefinido：me levanté。"},
    {"topic": "比較級 más que", "q": "Este libro es más interesante ___ el otro.", "zh": "這本書比另一本有趣。", "opts": ["que", "como", "de", "tan"], "a": 0, "exp": "優等比較級結構為 más + 形容詞 + que，故空格填 que。"},
    {"topic": "比較級 tan como", "q": "Ella es tan alta ___ su hermana.", "zh": "她和她姊姊一樣高。", "opts": ["como", "que", "de", "tanto"], "a": 0, "exp": "同等比較結構為 tan + 形容詞 + como，故空格填 como。"},
    {"topic": "最高級", "q": "Es el restaurante ___ caro de toda la ciudad.", "zh": "這是全城最貴的餐廳。", "opts": ["más", "tan", "muy", "tanto"], "a": 0, "exp": "最高級結構為 el/la + 名詞 + más + 形容詞 + de。"},
    {"topic": "不規則比較級", "q": "Esta película es ___ que la anterior.", "zh": "這部電影比上一部更好。", "opts": ["mejor", "más buena", "muy buena", "tan buena"], "a": 0, "exp": "bueno 的比較級用不規則形 mejor，不說 más bueno。"},
    {"topic": "未完成過去式（描述時間）", "q": "Cuando llegué a casa, ___ las diez de la noche.", "zh": "我到家的時候是晚上十點。", "opts": ["eran", "fueron", "son", "serán"], "a": 0, "exp": "敘述過去的時間或背景用 imperfecto；ser 第三人稱複數為 eran。"}
  ],

  "grammar": [
    {"topic": "形容詞性數配合", "q": "La casa es muy ___.", "zh": "這房子很漂亮。", "opts": ["bonita", "bonito", "bonitos", "bonitas"], "a": 0, "exp": "casa 為陰性單數，形容詞須配合為陰性單數 bonita。"},
    {"topic": "形容詞性數配合", "q": "Los zapatos son ___.", "zh": "這雙鞋是新的。", "opts": ["nuevos", "nuevo", "nueva", "nuevas"], "a": 0, "exp": "zapatos 為陽性複數，形容詞配合為 nuevos。"},
    {"topic": "gustar 結構", "q": "A nosotros nos ___ viajar.", "zh": "我們喜歡旅行。", "opts": ["gusta", "gustan", "gustamos", "gustas"], "a": 0, "exp": "gustar 主詞為單一動作 viajar，動詞用單數 gusta；間接受詞用 nos。"},
    {"topic": "gustar 結構", "q": "A ellos les ___ las películas españolas.", "zh": "他們喜歡西班牙電影。", "opts": ["gustan", "gusta", "gustas", "gustamos"], "a": 0, "exp": "主詞為複數 las películas，動詞用 gustan；間接受詞 les。"},
    {"topic": "encantar 結構", "q": "A mí me ___ esta ciudad.", "zh": "我超愛這座城市。", "opts": ["encanta", "encantan", "encanto", "encantas"], "a": 0, "exp": "encantar 用法同 gustar；單數主詞 ciudad 用 encanta。"},
    {"topic": "所有格形容詞", "q": "___ casa es muy grande. (你的)", "zh": "你的房子很大。", "opts": ["Tu", "Tus", "Mi", "Su"], "a": 0, "exp": "casa 為單數，第二人稱所有格單數為 tu（無重音符號）。"},
    {"topic": "所有格形容詞", "q": "Estos son ___ libros. (他們的)", "zh": "這些是他們的書。", "opts": ["sus", "su", "tus", "nuestros"], "a": 0, "exp": "libros 為複數，第三人稱所有格配合複數為 sus。"},

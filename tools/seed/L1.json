  "grammar": [
    {"topic": "主格代名詞", "q": "___ somos estudiantes.", "zh": "我們是學生。", "opts": ["Nosotros", "Yo", "Tú", "Él"], "a": 0, "exp": "動詞 somos 為 ser 第一人稱複數，對應主格代名詞 nosotros（我們）。"},
    {"topic": "ser vs estar", "q": "Yo ___ cansado hoy.", "zh": "我今天很累。", "opts": ["estoy", "soy", "es", "está"], "a": 0, "exp": "estar 表暫時狀態或心情（累）；第一人稱單數為 estoy。"},
    {"topic": "規則動詞現在式 -ar", "q": "Ella ___ español muy bien.", "zh": "她西班牙語說得很好。", "opts": ["habla", "hablo", "hablas", "hablan"], "a": 0, "exp": "-ar 規則動詞 hablar，第三人稱單數去 -ar 加 -a：habla。"},
    {"topic": "規則動詞現在式 -er", "q": "Nosotros ___ paella los domingos.", "zh": "我們週日吃海鮮飯。", "opts": ["comemos", "come", "como", "comen"], "a": 0, "exp": "-er 規則動詞 comer，第一人稱複數字尾為 -emos：comemos。"},
    {"topic": "規則動詞現在式 -ir", "q": "Yo ___ en Taipei.", "zh": "我住在台北。", "opts": ["vivo", "vives", "vive", "viven"], "a": 0, "exp": "-ir 規則動詞 vivir，第一人稱單數字尾為 -o：vivo。"},
    {"topic": "ser 表來源", "q": "Tú ___ de México, ¿verdad?", "zh": "你來自墨西哥，對吧？", "opts": ["eres", "soy", "es", "son"], "a": 0, "exp": "表國籍／來源用 ser de；ser 第二人稱單數為 eres。"},
    {"topic": "不定冠詞陰性", "q": "Hay ___ mesa en la sala.", "zh": "客廳裡有一張桌子。", "opts": ["una", "un", "unas", "unos"], "a": 0, "exp": "mesa 為陰性單數名詞，不定冠詞用 una。"},
